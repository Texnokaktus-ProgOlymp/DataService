@model Texnokaktus.ProgOlymp.Data.Models.ContestRegistrations

@{
    ViewBag.Title = Model.ContestTitle;
    Layout = "_Layout";
}

<div class="d-flex flex-row justify-content-between">
    <a class="btn btn-primary align-content-center" asp-controller="Contests" asp-action="Contest" asp-route-contestName="@Model.ContestName">Назад</a>
    <h2>@Model.ContestTitle</h2>
    <a class="btn btn-success align-content-center" asp-action="Excel" asp-route-contestName="@Model.ContestName">Скачать в формате Excel</a>
</div>

<table class="table table-borderless table-striped align-middle">
    <thead>
    <tr>
        <th>UID</th>
        <th>ФИО</th>
        @* <th>Дата рождения</th> *@
        <th>Класс</th>
        <th>Возрастная группа</th>
        @* <th>СНИЛС</th> *@
        <th>Email</th>
        <th>ОУ</th>
        <th>Регион</th>
        @* <th>Родитель</th> *@
        @* <th>Email (родитель)</th> *@
        @* <th>Телефон (родитель)</th> *@
        <th>Наставник</th>
        <th>ОУ (наставник)</th>
        @* <th>Email (наставник)</th> *@
        @* <th>Телефон (наставник)</th> *@
        <th>Участие в отборочным туре</th>
        <th>Участие в очном туре</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var registration in Model.Registrations)
    {
        <tr>
            <td>@registration.Uid</td>
            <td>@registration.ParticipantData.Name.FullName</td>
            @* <td>@application.BirthDate.ToString("dd.MM.yyyy")</td> *@
            <td>@registration.ParticipantData.Grade</td>
            @if (registration.ParticipantData.AgeGroup is { } ageGroup)
            {
                <td>@(ageGroup.StartGrade)&ndash;@(ageGroup.EndGrade) класс</td>
            }
            else
            {
                <td></td>
            }
            @* <td>@application.Snils</td> *@
            <td>@registration.ParticipantData.Email</td>
            <td>@registration.ParticipantData.School</td>
            <td>@registration.ParticipantData.Region</td>
            @* <td>@application.Parent.LastName @application.Parent.FirstName @application.Parent.Patronym</td> *@
            @* <td>@application.Parent.Email</td> *@
            @* <td>@application.Parent.Phone</td> *@
            <td>@registration.TeacherData.Name.FullName</td>
            <td>@registration.TeacherData.School</td>
            @* <td>@registration.TeacherData.Email</td> *@
            @* <td>@registration.TeacherData.Phone</td> *@
            @await Html.PartialAsync("ContestStageParticipationPartial", (Model.PreliminaryYandexContestId, registration.PreliminaryStageParticipation))
            @await Html.PartialAsync("ContestStageParticipationPartial", (Model.FinalYandexContestId, registration.FinalStageParticipation))
        </tr>
    }
    </tbody>
</table>
